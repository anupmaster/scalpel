  },
  "dependencies": {
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@prisma/client": "5.14.0",
    "zod": "3.23.8",
    "next-auth": "4.24.7",
    "@tanstack/react-query": "5.40.0",
    "tailwindcss": "3.4.4",
    "lucide-react": "0.379.0",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "prisma": "5.14.0",
    "@types/node": "20.14.1",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.3",
    "prettier": "3.3.0",
    "prettier-plugin-tailwindcss": "0.6.1",
    "vitest": "1.6.0",
    "@testing-library/react": "16.0.0",
    "@testing-library/jest-dom": "6.4.5",
    "husky": "9.0.11",
    "lint-staged": "15.2.5",
    "autoprefixer": "10.4.19",
